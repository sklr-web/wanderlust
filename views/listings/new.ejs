
<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2"> 
        <!-- <br><br> -->
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

    <div class="mb-3">
         <lable for="title" class="form-label">Title</lable>
         <input name="listing[title]"
          placeholder="Add a catchy title"
          type="text" 
          class="form-control"
          required>
          <div class="valid-feedback">Title looks good</div>
    </div>

        <div class="mb-3">
            <lable for="description" class="form-label">Description</lable>
            <textarea 
             name="listing[description]" 
             class="form-control" 
             required>
            </textarea>
            <div class="invalid-feedback">Please enter a short description</div>
        </div>


    
            <div class="mb-3">
             <lable for="image" class="form-label">Upload Image</lable>
             <input name="image"  
             type="file" class="form-control">
             required
         </div>

        <div class="row">
             <div class="mb-3 col-md-4">
              <lable for="price" class="form-label">Price</lable>
              <input name="listing[price]" 
               placeholder="1200" 
               class="form-control"
               required>
               <div class="valid-feedback">Price should be valid</div>
             </div>

           <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">country</lable>
            <input name="listing[country]"
            placeholder="india" 
            type="text" class="form-control"
            required>
            <div class="invalid-feedback">country name should be valid</div>
           </div>
        </div>

        <div>
            <lable for="location" class="form-label">Location</lable>
            <input name="listing[location]" 
             placeholder="jaipur, rajastan" 
             type="text" 
             class="form-control"
             required>
             <div class="valid-feedback">Location should be valid</div>
        </div>

        <button class="btn add-btn mt-3">Add</button>
     
    </form>
</body>
</html>
</div>
</div>




